---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { filterPublishedByLang, sortByDateDesc } from '../../lib/posts'
import { useTranslations } from '../../i18n/utils'

export async function getStaticPaths() {
  return [
    { params: { lang: 'pt-BR' } },
    { params: { lang: 'en' } },
  ]
}

const { lang } = Astro.params as { lang: 'pt-BR' | 'en' }
const t = useTranslations(lang)
const all = await getCollection('posts')
const posts = sortByDateDesc(filterPublishedByLang(all, lang))
---

<BaseLayout
  title={`Precisian Blog — ${lang === 'pt-BR' ? 'Início' : 'Home'}`}
  description={t('site.tagline')}
>
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="max-w-3xl">
      <header class="mb-12">
        <h1 class="font-display text-5xl font-bold mb-3">Precisian Blog</h1>
        <p class="text-lg text-fg-muted">{t('site.tagline')}</p>
      </header>
      <div>
        {posts.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </div>
</BaseLayout>
