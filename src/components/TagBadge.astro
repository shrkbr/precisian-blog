---
// precisian-blog/src/components/TagBadge.astro
import { getLangFromUrl } from '../i18n/utils'

interface Props {
  tag: string
  href?: string
}

const { tag, href } = Astro.props
const lang = getLangFromUrl(Astro.url)
const url = href ?? `/blog/${lang}/tags/${tag}`
---

<a
  href={url}
  class="inline-block px-2 py-0.5 rounded-full text-xs font-mono bg-bg-elevated border border-border text-fg-muted hover:text-accent hover:border-accent transition"
>
  #{tag}
</a>
