---
import BaseLayout from './BaseLayout.astro'
import TableOfContents from '../components/TableOfContents.astro'
import ReadingProgress from '../components/ReadingProgress.astro'
import TagBadge from '../components/TagBadge.astro'
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import { getCollection } from 'astro:content'
import { findTranslation } from '../lib/posts'
import { buildBlogPostingJsonLd, countWords, buildBreadcrumbListJsonLd } from '../lib/schema'
import type { CollectionEntry } from 'astro:content'
import type { MarkdownHeading } from 'astro'

interface Props {
  post: CollectionEntry<'posts'>
  headings: MarkdownHeading[]
}

const { post, headings } = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const { title, description, publishedAt, updatedAt, readingTimeMinutes, tags, author } = post.data

const allPosts = await getCollection('posts')
const otherLang = lang === 'pt-BR' ? 'en' : 'pt-BR'
const translation = findTranslation(allPosts, post, otherLang)

const alternateUrl: Partial<Record<'pt-BR' | 'en', string>> = {
  [lang]: `/blog/${lang}/posts/${post.data.slug}`,
}
if (translation) {
  alternateUrl[otherLang] = `/blog/${otherLang}/posts/${translation.data.slug}`
}

const canonicalUrl = new URL(`/blog/${lang}/posts/${post.data.slug}`, Astro.site).toString()
const jsonLd = buildBlogPostingJsonLd({
  title,
  description,
  url: canonicalUrl,
  publishedAt,
  updatedAt,
  author,
  lang,
  wordCount: countWords(post.body ?? ''),
  tags,
  mentions: post.data.mentions,
  about: post.data.about,
  citations: post.data.citations,
  lastReviewed: post.data.lastReviewed,
})

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://precisian.io'
const breadcrumbs = buildBreadcrumbListJsonLd([
  { name: t('nav.home'), url: `${siteOrigin}/blog/${lang}/` },
  { name: t('nav.tags'), url: `${siteOrigin}/blog/${lang}/tags/` },
  { name: title, url: canonicalUrl },
])
---

<BaseLayout title={title} description={description} alternateUrl={alternateUrl}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <meta slot="head" property="article:published_time" content={publishedAt.toISOString()} />
  {updatedAt && <meta slot="head" property="article:modified_time" content={updatedAt.toISOString()} />}
  <meta slot="head" property="article:author" content="https://precisian.io" />
  <meta slot="head" property="article:section" content={tags[0] ?? 'blog'} />
  {tags.map((tag) => <meta slot="head" property="article:tag" content={tag} />)}
  {readingTimeMinutes && <meta slot="head" name="twitter:label1" content={lang === 'pt-BR' ? 'Tempo de leitura' : 'Reading time'} />}
  {readingTimeMinutes && <meta slot="head" name="twitter:data1" content={`${readingTimeMinutes} ${t('post.readingTime')}`} />}
  <meta slot="head" name="twitter:label2" content={lang === 'pt-BR' ? 'Categoria' : 'Section'} />
  <meta slot="head" name="twitter:data2" content={tags[0] ?? 'blog'} />

  <ReadingProgress />

  <div class="max-w-6xl mx-auto px-6 py-12 grid lg:grid-cols-[1fr_240px] gap-12">
    <article class="min-w-0">
      <header class="mb-10 pb-6 border-b border-border">
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 leading-tight">{title}</h1>
        <p class="text-lg text-fg-muted mb-4">{description}</p>
        <div class="flex flex-wrap items-center gap-4 text-sm text-fg-muted">
          <time datetime={publishedAt.toISOString()}>
            {publishedAt.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {readingTimeMinutes && <span>· {readingTimeMinutes} {t('post.readingTime')}</span>}
          <span>· {author}</span>
        </div>
      </header>

      <div class="prose prose-invert prose-lg max-w-none">
        <slot />
      </div>

      <footer class="mt-12 pt-6 border-t border-border">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      </footer>
    </article>

    <aside class="hidden lg:block">
      <div class="sticky top-8">
        <TableOfContents headings={headings} />
      </div>
    </aside>
  </div>
</BaseLayout>
